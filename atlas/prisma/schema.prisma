// 07.5 — SavedSearch (Alert): the retention engine. Keyed to the guest
// session (07.1) until real accounts land; the swap is the sessionId column.
// Filters are concrete columns, not JSON — MVP has exactly these three knobs.
model SavedSearch {
  id            String    @id @default(cuid())
  sessionId     String
  queryText     String? // contains-match on title/brand, like /ara
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  maxPriceKurus Int?
  active        Boolean   @default(true)
  lastMatchedAt DateTime?
  createdAt     DateTime  @default(now())
  notifications Notification[]

  @@index([active])
  @@index([sessionId])
}

// 07.5 — one table for all notifications; MVP delivers in-app (dashboard +
// header badge), email/push channels attach later.
model Notification {
  id            String    @id @default(cuid())
  sessionId     String
  type          String // alert_match | (order events later)
  listingId     String?
  listing       Listing?  @relation(fields: [listingId], references: [id])
  savedSearchId String?
  savedSearch   SavedSearch? @relation(fields: [savedSearchId], references: [id])
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([sessionId, readAt])
}

