model ListingPhoto {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])
  position  Int
  url       String
  width     Int
  height    Int
  isFlaw    Boolean @default(false)
  flawLabel String?

  @@index([listingId, position])
}

// 07.3 — the oversell guard. stock_available = stock - active holds, checked atomically.
model StockHold {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  userId    String
  qty       Int      @default(1)
  status    String   @default("active") // active | converted | expired | released
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([listingId, status, expiresAt])
}

