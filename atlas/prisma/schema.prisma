  resolutionNote String? // plain-language explanation — outcomes are trust moments (10.3)
  openedAt       DateTime  @default(now())
  respondedAt    DateTime?
  resolvedAt     DateTime?

  @@index([status, openedAt])
}

// 10.4 penalty matrix. Strikes expire after 12 months; 3 active → suspension.
model Strike {
  id        String   @id @default(cuid())
  sellerId  String
  seller    Seller   @relation(fields: [sellerId], references: [id])
  reason    String // misgraded_item | shipping_sla | seller_fault_cancel | fake_discount | off_platform
  orderId   String?
  detail    String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([sellerId, expiresAt])
}

